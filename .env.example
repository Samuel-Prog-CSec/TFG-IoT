# ============================================================================
# CONFIGURACIÓN DEL ENTORNO - RFID Games Platform
# ============================================================================
# Copiar este archivo como .env y configurar los valores
#
#   cp .env.example .env
#
# Autor: Samuel Blanchart Pérez
# Versión: 1.0.0
# ============================================================================

# ============================================================================
# SERVIDOR
# ============================================================================
PORT=5000
NODE_ENV=development
# Opciones: development | production | test

# ============================================================================
# BASE DE DATOS - MongoDB
# ============================================================================
# Para desarrollo local con Docker:
MONGO_URI=mongodb://mongo:27017/rfid_games_db

# Para MongoDB Atlas (producción):
# MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/rfid_games_db

# ============================================================================
# CACHÉ - Redis
# ============================================================================
# Para desarrollo local con Docker:
REDIS_URL=redis://redis:6379

# Para Redis Cloud (producción):
# REDIS_URL=redis://:password@host:port

# Opcional: prefijo para keys (default: rfid-games:)
# REDIS_KEY_PREFIX=rfid-games:

# ============================================================================
# AUTENTICACIÓN JWT
# ============================================================================
# ⚠️ IMPORTANTE: Generar valores únicos y seguros para producción
# Usar: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

JWT_SECRET=tu_secret_jwt_minimo_32_caracteres_aqui
JWT_REFRESH_SECRET=tu_secret_refresh_minimo_32_caracteres_aqui

# Tiempos de expiración
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================================================
# SEGURIDAD - CORS
# ============================================================================
# Lista de orígenes permitidos (separados por coma)
CORS_WHITELIST=http://localhost:3000,http://localhost:5173,http://localhost:80,http://localhost

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_MAX_REQUESTS_DEV=2000
RATE_LIMIT_AUTH_MAX_REQUESTS_DEV=400

# ============================================================================
# ALMACENAMIENTO - Supabase Storage (para assets de juegos)
# ============================================================================
# Obtener de: https://supabase.com/dashboard/project/[project]/settings/api
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_KEY=tu_service_key_aqui
SUPABASE_BUCKET=game-assets

# ============================================================================
# RFID - Fuente de eventos (cliente Web Serial)
# Opciones: client | disabled
# ============================================================================
RFID_SOURCE=client

# ============================================================================
# MONITOREO - Sentry (opcional)
# ============================================================================
SENTRY_ENABLED=false
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Frontend
VITE_SENTRY_ENABLED=false
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ============================================================================
# LOGGING
# ============================================================================
# Nivel de log: error | warn | info | debug
# LOG_LEVEL=info

# ============================================================================
# SUPER ADMIN (para seeder inicial)
# ============================================================================
SUPER_ADMIN_EMAIL=admin@test.com
SUPER_ADMIN_PASSWORD=Admin1234!
