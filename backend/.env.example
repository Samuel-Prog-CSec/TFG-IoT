# ============================================================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================================================
PORT=5000
NODE_ENV=development

# ============================================================================
# CONFIGURACIÓN DE MONGODB (localhost para desarrollo por defecto - cambiar en producción a una URI de MongoDB Atlas)
# ============================================================================
MONGO_URI=mongodb://localhost:27017/rfid_games

# ============================================================================
# CONFIGURACIÓN DE REDIS (localhost para desarrollo - Docker)
# En producción usar Upstash u otro servicio de Redis gestionado
# Ver docker/README.md para configuración con Docker
# ============================================================================
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=rfid-games:

# ============================================================================
# RFID - Fuente de eventos (cliente Web Serial)
# Opciones: client | disabled
# client: el navegador del profesor lee el puerto serial y envia eventos al backend
# disabled: desactiva el procesamiento de RFID
# ============================================================================
RFID_SOURCE=client

# ============================================================================
# CONFIGURACIÓN DE CORS
# Lista de orígenes permitidos separados por comas
# ============================================================================
CORS_WHITELIST=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# ============================================================================
# CONFIGURACIÓN DE AUTENTICACIÓN JWT
# IMPORTANTE: Cambiar estos secretos en producción
# AUTH_BYPASS_FOR_DEV: true para deshabilitar autenticación en desarrollo
# ============================================================================
AUTH_BYPASS_FOR_DEV=true
JWT_SECRET=937f2376aac397b60d23e93f5b1b03bd6bf0a12a81178cc446fe92e3a7890d37a04abef4a01a038a2b209fee098deb9a1667e3a18f3da5c92c27c5d4aa460af7
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=ad4b33876bc89a2cb9a17cd0721d816b7a319c8c3d1231d7f245da4535fc168b6f3e130b36b54a68577afe32dacee2aa3f7c280e0fb5c067c903de027660927e
JWT_REFRESH_EXPIRES_IN=30d

# ============================================================================
# CONFIGURACIÓN DE BCRYPT
# ============================================================================
BCRYPT_SALT_ROUNDS=10

# ============================================================================
# CONFIGURACIÓN DE RATE LIMITING
# ============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# CONFIGURACIÓN DE SENTRY (MONITOREO DE ERRORES)
# Dejar vacío si no se usa Sentry en desarrollo
# ============================================================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILES_SAMPLE_RATE=1.0

# ============================================================================
# CONFIGURACIÓN DE SUPABASE (ALMACENAMIENTO DE ASSETS)
# Dejar vacío si no se usa Supabase en desarrollo
# ============================================================================
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================================
# CONFIGURACIÓN DEL SUPER ADMIN (Seeder)
# ============================================================================
SUPER_ADMIN_EMAIL=admin@test.com
SUPER_ADMIN_PASSWORD=Admin1234!

# ============================================================================
# CONFIGURACIÓN DEL MOTOR DE JUEGO
# ============================================================================
DEFAULT_ROUND_TIME=15
DEFAULT_POINTS_PER_CORRECT=10
DEFAULT_PENALTY_PER_ERROR=-2
ACTIVE_PLAYS_WARNING_THRESHOLD=1000
PLAY_TIMEOUT_MS=3600000