# ============================================================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================================================
PORT=5000
NODE_ENV=development

# ============================================================================
# CONFIGURACIÓN DE MONGODB
# ============================================================================
MONGO_URI=mongodb://localhost:27017/rfid_games_demo

# ============================================================================
# CONFIGURACIÓN DEL PUERTO SERIE RFID
# Windows: COM3, COM4, etc.
# Linux/Mac: /dev/ttyUSB0, /dev/ttyACM0, etc.
# ============================================================================
SERIAL_PORT=COM3
SERIAL_BAUD_RATE=115200
RFID_MAX_RECONNECT_ATTEMPTS=10
RFID_RECONNECT_DELAY_MS=5000

# ============================================================================
# CONFIGURACIÓN DE CORS
# Lista de orígenes permitidos separados por comas
# ============================================================================
CORS_WHITELIST=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# ============================================================================
# CONFIGURACIÓN DE AUTENTICACIÓN JWT
# Generar secrets aleatorios largos (mínimo 32 caracteres)
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# El servidor NO ARRANCARÁ sin estos valores configurados
# ============================================================================
JWT_SECRET=change-me-generate-random-64-char-hex-string-with-crypto-randomBytes
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-generate-different-random-64-char-hex-string
JWT_REFRESH_EXPIRES_IN=30d

# ============================================================================
# CONFIGURACIÓN DE BCRYPT
# ============================================================================
BCRYPT_SALT_ROUNDS=10

# ============================================================================
# CONFIGURACIÓN DE RATE LIMITING
# ============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# CONFIGURACIÓN DE SENTRY (MONITOREO DE ERRORES)
# Obtener DSN en: https://sentry.io/
# ============================================================================
SENTRY_DSN=your-sentry-dsn-here
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILES_SAMPLE_RATE=1.0

# ============================================================================
# CONFIGURACIÓN DE SUPABASE (ALMACENAMIENTO DE ASSETS)
# ============================================================================
SUPABASE_URL=your-supabase-url-here
SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# ============================================================================
# CONFIGURACIÓN DEL MOTOR DE JUEGO
# ============================================================================
DEFAULT_ROUND_TIME=15
DEFAULT_POINTS_PER_CORRECT=10
DEFAULT_PENALTY_PER_ERROR=-2
MAX_ACTIVE_PLAYS=1000
PLAY_TIMEOUT_MS=3600000

# ============================================================================
# CONFIGURACIÓN DE REDIS (BLACKLIST Y CACHÉ)
# Requerido para blacklist de tokens escalable y cache de queries
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
