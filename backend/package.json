{
  "name": "rfid-games-backend",
  "version": "0.4.0",
  "description": "Backend server for RFID educational games - MERN stack",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "seed": "node seeders/index.js",
    "seed:reset": "node seeders/index.js --reset",
    "seed:if-empty": "node scripts/seed-if-empty.js",
    "migrate:sessions": "node scripts/migrate-session-status.js",
    "bench:sessions": "node scripts/benchmark-session-reads.js",
    "drop-db": "node scripts/drop-db.js",
    "lint": "eslint .",
    "lint:test": "eslint ./tests/**/*.js",
    "lint:staged": "eslint",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.js\" \"seeders/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"seeders/**/*.js\"",
    "test": "cross-env NODE_ENV=test jest",
    "security:check-&-fix": "npm audit && npm audit fix",
    "audit:full": "npm audit",
    "audit:prod": "npm audit --omit=dev",
    "audit:full:json": "npm audit --json",
    "audit:prod:json": "npm audit --omit=dev --json",
    "deps:update-minor": "npx npm-check-updates -t minor -u && npm install",
    "deps:analyze": "npx npm-check-updates && npx depcheck && npm outdated"
  },
  "keywords": [
    "rfid",
    "backend",
    "educational_games",
    "mern",
    "iot",
    "nodejs",
    "express",
    "mongodb",
    "socket.io",
    "sentry",
    "api_rest"
  ],
  "author": "Samuel Blanchart Pérez",
  "dependencies": {
    "@sentry/node": "9.47.1",
    "@sentry/profiling-node": "9.47.1",
    "@sentry/react": "^10.42.0",
    "@supabase/supabase-js": "^2.98.0",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.0",
    "file-type": "16.5.4",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.4",
    "multer": "^2.1.1",
    "music-metadata": "^11.12.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^4.0.1",
    "globals": "^17.4.0",
    "ioredis-mock": "^8.13.1",
    "jest": "^30.2.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2",
    "ts-api-utils": "^2.4.0"
  },
  "overrides": {
    "@sentry/node": {
      "minimatch": "^10.2.1"
    },
    "@sentry/profiling-node": {
      "minimatch": "^10.2.1"
    }
  },
  "engines": {
    "node": ">=24.12.0"
  }
}
