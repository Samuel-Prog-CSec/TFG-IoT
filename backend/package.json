{
  "name": "rfid-games-backend",
  "version": "0.1.0",
  "description": "Backend server for RFID educational games - MERN stack",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "seed": "node seeders/index.js",
    "seed:reset": "node seeders/index.js --reset",
    "token": "node scripts/get-test-token.js",
    "lint": "eslint src/**/*.js seeders/**/*.js",
    "lint:fix": "eslint src/**/*.js seeders/**/*.js --fix",
    "format": "prettier --write \"src/**/*.js\" \"seeders/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"seeders/**/*.js\"",
    "test": "echo \"Error: no test specified\" && exit 1",
    "security:check-&-fix": "npm audit && npm audit fix",
    "deps:update-minor": "npx npm-check-updates -t minor -u && npm install",
    "deps:update-major": "npx npm-check-updates -t major -u && npm install",
    "deps:analyze": "npx npm-check-updates && npx depcheck && npm outdated"
  },
  "keywords": [
    "rfid",
    "backend",
    "educational_games",
    "mern",
    "iot",
    "nodejs",
    "express",
    "mongodb",
    "socket.io",
    "serialport",
    "sentry",
    "api_rest"
  ],
  "author": "Samuel Blanchart Pérez",
  "dependencies": {
    "@sentry/node": "^10.26.0",
    "@sentry/profiling-node": "^10.26.0",
    "@serialport/parser-readline": "^13.0.0",
    "@supabase/supabase-js": "^2.86.0",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.0.0",
    "multer": "^2.0.2",
    "serialport": "^13.0.0",
    "socket.io": "^4.8.1",
    "winston": "^3.18.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.5.4",
    "nodemon": "^3.1.11",
    "prettier": "^3.4.2"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
