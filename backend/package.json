{
  "name": "rfid-games-backend",
  "version": "0.2.0",
  "description": "Backend server for RFID educational games - MERN stack",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "seed": "node seeders/index.js",
    "seed:reset": "node seeders/index.js --reset",
    "migrate:sessions": "node scripts/migrate-session-status.js",
    "drop-db": "node scripts/drop-db.js",
    "lint": "eslint .",
    "lint:test": "eslint ./tests/**/*.js",
    "lint:staged": "eslint",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.js\" \"seeders/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"seeders/**/*.js\"",
    "test": "cross-env NODE_ENV=test jest",
    "security:check-&-fix": "npm audit && npm audit fix",
    "deps:update-minor": "npx npm-check-updates -t minor -u && npm install",
    "deps:update-major": "npx npm-check-updates -t major -u && npm install",
    "deps:analyze": "npx npm-check-updates && npx depcheck && npm outdated"
  },
  "keywords": [
    "rfid",
    "backend",
    "educational_games",
    "mern",
    "iot",
    "nodejs",
    "express",
    "mongodb",
    "socket.io",
    "sentry",
    "api_rest"
  ],
  "author": "Samuel Blanchart Pérez",
  "dependencies": {
    "@sentry/node": "^10.38.0",
    "@sentry/profiling-node": "^10.38.0",
    "@supabase/supabase-js": "^2.95.3",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^3.0.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "file-type": "16.5.4",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.1.6",
    "multer": "^2.0.2",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.3.0",
    "ioredis-mock": "^8.13.1",
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.1",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2",
    "ts-api-utils": "^1.4.0"
  },
  "engines": {
    "node": ">=24.12.0"
  }
}
