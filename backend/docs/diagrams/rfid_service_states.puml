@startuml RFID_Service_States

!theme plain
skinparam backgroundColor #FEFEFE

title Estados del Servicio RFIDService

state "disabled" as DISABLED {
    DISABLED : RFID_ENABLED != true
    DISABLED : Servicio desactivado
}

state "misconfigured" as MISCONF {
    MISCONF : RFID_ENABLED = true
    MISCONF : pero SERIAL_PORT vacío
}

state "reconnecting" as RECON {
    RECON : Intentando conectar
    RECON : Backoff exponencial
    RECON : Max 10 intentos
}

state "connected" as CONN {
    CONN : Conexión establecida
    CONN : Leyendo eventos JSON
    CONN : Métricas activas
}

state "disconnected" as DISC {
    DISC : Conexión perdida
    DISC : Auto-retry en 5s
}

state "failed" as FAILED {
    FAILED : Max reintentos alcanzado
    FAILED : Requiere intervención
}

[*] --> DISABLED : RFID_ENABLED != true

[*] --> MISCONF : RFID_ENABLED = true\nSERIAL_PORT vacío

[*] --> RECON : RFID_ENABLED = true\nSERIAL_PORT configurado

RECON --> CONN : Éxito
RECON --> DISC : Error (intento < 10)
RECON --> FAILED : Error (intento >= 10)

CONN --> DISC : Desconexión USB\no error serial

DISC --> RECON : Auto-retry (5s)

note right of CONN
  emit('status', 'connected')
  emit('rfid_event', {...})
end note

note left of FAILED
  Requiere reinicio
  del servidor o
  intervención manual
end note

@enduml
