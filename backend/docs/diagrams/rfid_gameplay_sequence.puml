@startuml RFID_Gameplay_Sequence

!theme plain
skinparam backgroundColor #FEFEFE
skinparam sequenceMessageAlign center

title Flujo de Gameplay - Escaneo RFID

actor Alumno as User
participant "Frontend" as FE
participant "Socket.IO" as Socket
participant "GameEngine" as Engine
participant "RFIDService" as RFID
participant "Web Serial" as WebSerial
participant "Sensor\nRC522" as Sensor
database "MongoDB" as DB

== Inicio de Partida ==

User -> FE : Inicia partida
FE -> Socket : start_play\n{ playId }
Socket -> Engine : startPlay(play, session)

Engine -> Engine : Verificar tarjetas\nno en uso

Engine -> Engine : Bloquear UIDs en\ncardUidToPlayId Map

opt PERSIST_ROUND_START_EVENTS=true
    Engine -> DB : Registrar evento\n'round_start'
end

Engine -> Socket : new_round\n{ challenge, timeLimit }
Socket -> FE : new_round
FE -> User : "Busca: España 🇪🇸"

== Escaneo de Tarjeta ==

User -> Sensor : Escanea tarjeta\nfísica
Sensor -> WebSerial : JSON:\n{"event":"card_detected",\n"uid":"32B8FA05"}
WebSerial -> Socket : rfid_scan_from_client
Socket -> RFID : ingestEvent
RFID -> Engine : handleCardScan(uid)

Engine -> Engine : 1. cardUidToPlayId.get(uid)\n→ playId

Engine -> Engine : 2. activePlays.get(playId)\n→ playState

Engine -> Engine : 3. Verificar\nawaitingResponse

Engine -> Engine : 4. uidToMapping.get(uid)\n→ cardMapping

Engine -> Engine : 5. Comparar con\ncurrentChallenge

alt Respuesta Correcta
    Engine -> DB : addEventAtomic('correct',\nadvanceRound=true)
    Engine -> Socket : validation_result\n{ isCorrect: true, +10 pts }
    Socket -> FE : validation_result
    FE -> User : ✅ ¡Correcto! +10 puntos
else Respuesta Incorrecta
    Engine -> DB : addEventAtomic('error',\nadvanceRound=true)
    Engine -> Socket : validation_result\n{ isCorrect: false, -2 pts }
    Socket -> FE : validation_result
    FE -> User : ❌ Incorrecto -2 puntos
end

== Siguiente Ronda (tras 4s delay) ==

opt PERSIST_ROUND_START_EVENTS=true
    Engine -> DB : Registrar evento\n'round_start'
end
Engine -> Socket : new_round\n{ nextChallenge }
Socket -> FE : new_round
FE -> User : "Busca: Francia 🇫🇷"

@enduml
