{
  "name": "tfg-iot",
  "version": "0.3.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "prepare": "husky",
    "audit:root": "npm audit",
    "audit:backend:prod": "npm --prefix backend run audit:prod",
    "audit:frontend:prod": "npm --prefix frontend run audit:prod",
    "audit:prod": "npm run audit:backend:prod && npm run audit:frontend:prod",
    "audit:all": "npm run audit:root && npm --prefix backend run audit:full && npm --prefix frontend run audit:full"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Samuel-Prog-CSec/TFG-IoT.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Samuel-Prog-CSec/TFG-IoT/issues"
  },
  "homepage": "https://github.com/Samuel-Prog-CSec/TFG-IoT#readme",
  "dependencies": {
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7"
  },
  "overrides": {
    "ajv": "^8.18.0"
  },
  "lint-staged": {
    "backend/**/*.js": [
      "npm --prefix backend run lint:staged --",
      "npm --prefix backend test -- --findRelatedTests --passWithNoTests"
    ],
    "frontend/**/*.{js,jsx}": [
      "npm --prefix frontend run lint:staged --"
    ]
  }
}
